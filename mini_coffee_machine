MENU = {
    "espresso": {
        "ingredients": {
            "water": 50,
            "coffee": 18,
        },
        "cost": 1.5,
    },
    "latte": {
        "ingredients": {
            "water": 200,
            "milk": 150,
            "coffee": 24,
        },
        "cost": 2.5,
    },
    "cappuccino": {
        "ingredients": {
            "water": 250,
            "milk": 100,
            "coffee": 24,
        },
        "cost": 3.0,
    }
}

resources = {
    "water": 300,
    "milk": 200,
    "coffee": 100,
    "Money":0
}


def money():
    """Todo calculate the amount of money"""
    print("please insert coins")
    quarter=float(input("please insert quarters: "))
    dime=float(input("please insert dimes: "))
    nickle=float(input("please insert nickles: "))
    pennie=float(input("please insert pennies: "))
    monetary_value=(quarter*0.25)+(dime*0.10)+(nickle*0.05)+(pennie*0.01)
    return monetary_value

def order(drink):
    #ordering the drink
    global machine
    #first to check if we have enough resources
    for j in MENU[drink]["ingredients"]:
        if resources[j] < MENU[drink]["ingredients"][j]:
            print("Sorry, not enough",j)
            break
    # second: if we have enough resources , calculate the amount and move on and check if there are given enough amount
        elif resources[j] > MENU[drink]["ingredients"][j]:
            total_cost = money()
            if total_cost > MENU[drink]["cost"]:
                return_money = round(float(total_cost - MENU[drink]["cost"]), 2)
                print("The remaining money:", return_money,"$")
            #Third: Moving on to deduct the resources that have been used
            if total_cost >= MENU[drink]["cost"]:
                for i in  MENU[drink]["ingredients"]:
                    resources[i]-=MENU[drink]["ingredients"][i]
                    resources["Money"] += float(MENU[drink]["cost"])
                print(f"Here is your {drink}, Enjoy!")
                break
            if total_cost < MENU[drink]["cost"]:
                print("not enough money, Money refunded")
                break


machine=True
while machine:
    print("Welcome to the Coffee Machine App")
    customer_order=input("What would you like?(espresso/latte/cappuccino)\n").lower()
    if customer_order =="off":
        break
    elif customer_order=="report":
        print(resources)
    else:
        order(customer_order)
